	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#90A4AE"
			}
		},
		{
			"name": "Comments: Preprocessor",
			"scope": "comment.block.preprocessor",
			"settings": {
				"fontStyle": "",
				"foreground": "#90A4AE"
			}
		},
		{
			"scope": "storage.type.namespace.directive",
			"settings": {
				"foreground": "#CE93D8"
			}
		},
		{
			"scope": "keyword.other.unit.suffix.integer",
			"settings": {
				"foreground": "#FF8A80"
			}
		},
		{
			"name": "Local Variables",
			"scope": "variable.other.local",
			"settings": {
				"foreground": "#4DD0E1"
			}
		},
		{
			"name": "Comments: Documentation",
			"scope": [
				"comment.documentation",
				"comment.block.documentation"
			],
			"settings": {
				"foreground": "#66BB6A"
			}
		},
		{
			"name": "Invalid - Illegal",
